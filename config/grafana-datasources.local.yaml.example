# Generated By: Claude Code (Claude Opus 4.7)
# Datasource provisioning for local Grafana pointed at remote backends.
# UIDs match the dashboard JSON files so panels resolve without manual remapping.
#
# Setup:
#   1. cp config/grafana-datasources.local.yaml.example config/grafana-datasources.local.yaml
#   2. Edit URLs below to point at your Prometheus / Loki / Tempo endpoints.
#   3. make local-up
#
# The real file is .gitignored so personal endpoints (e.g. tailnet hostnames)
# never get committed.
apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    uid: PBFA97CFB590B2093
    access: proxy
    url: http://prometheus.example.local:9090
    isDefault: true
    editable: true

  - name: Loki
    type: loki
    uid: P8E80F9AEF21F6940
    access: proxy
    url: http://loki.example.local:3100
    editable: true

  - name: Tempo
    type: tempo
    uid: P214B5B846CF3925F
    access: proxy
    url: http://tempo.example.local:3200
    editable: true
