          "editorMode": "code",
          "expr": "max by (prompt_id, prompt_short, location, event_timestamp) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | session_id=~\"$session_id\" | project=~\"$project\" | host_name=~\"$host_name\" | label_format prompt_short=`{{ printf \"%.200s\" .prompt }}`, location=`{{ if hasPrefix \"sandbox\" .host_name }}~/sandboxes/{{ .host_name }}{{ else }}{{ regexReplaceAll \"/home/[^/]+\" .project \"~\" }}{{ end }}` [$__range]))",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "editorMode": "code",
          "expr": "sum by (prompt_id) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | session_id=~\"$session_id\" | project=~\"$project\" | host_name=~\"$host_name\" | unwrap cost_usd [$__range]))",
          "queryType": "instant",
          "refId": "B"
        }
      ],
      "title": "Cost per Prompt",
