{
  "title": "Claude Code — Sessions",
  "uid": "claude-sessions",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(claude_code_cost_usage_USD_total, project)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Permission Required",
      "type": "stat",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "noValue": "0"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "count(claude_session_permission{project=~\"$project\"} > 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "Working",
      "type": "stat",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "noValue": "0"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "count(claude_session_working{project=~\"$project\"} > 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "Ready",
      "type": "stat",
      "id": 3,
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "noValue": "0"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "count(claude_session_ready{project=~\"$project\"} > 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Active",
      "type": "stat",
      "id": 4,
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "noValue": "0"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "count(\n  (claude_session_permission{project=~\"$project\"} > 0)\n  or\n  (claude_session_working{project=~\"$project\"} > 0)\n  or\n  (claude_session_ready{project=~\"$project\"} > 0)\n) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "Session State History",
      "type": "state-timeline",
      "id": 5,
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70,
            "spanNulls": false
          },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "green", "value": 1 },
              { "color": "blue", "value": 2 },
              { "color": "orange", "value": 3 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "Ready", "color": "green", "index": 0 },
                "2": { "text": "Working", "color": "blue", "index": 1 },
                "3": { "text": "Permission Required", "color": "orange", "index": 2 }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "(claude_session_permission{project=~\"$project\"} * 0 + 3)\nor\n(claude_session_working{project=~\"$project\"} * 0 + 2)\nor\n(claude_session_ready{project=~\"$project\"} * 0 + 1)",
          "legendFormat": "{{session_id}} · {{project}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Current Sessions",
      "type": "table",
      "id": 6,
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "green", "value": 1 },
              { "color": "blue", "value": 2 },
              { "color": "orange", "value": 3 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "Ready", "color": "green", "index": 0 },
                "2": { "text": "Working", "color": "blue", "index": 1 },
                "3": { "text": "Permission Required", "color": "orange", "index": 2 }
              }
            }
          ],
          "custom": {
            "displayMode": "color-background"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "State" },
              { "id": "custom.width", "value": 180 }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "State", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "(claude_session_permission{project=~\"$project\"} * 0 + 3)\nor\n(claude_session_working{project=~\"$project\"} * 0 + 2)\nor\n(claude_session_ready{project=~\"$project\"} * 0 + 1)",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
